{
  "name": "blockdata-ct",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev --host 0.0.0.0 --port 4421",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "openvscode:up": "docker compose -f docker-compose.openvscode.yml up -d",
