    "@astrojs/starlight-tailwind": "^4.0.2",
    "@astrojs/vercel": "^9.0.4",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/nunito": "^5.2.7",
    "@keystatic/astro": "^5.0.6",
