    "fix:text-encoding": "node scripts/fix-text-encoding.mjs",
    "check:text-encoding": "node scripts/fix-text-encoding.mjs --check",
    "normalize:proposals": "node scripts/normalize-proposals.mjs",
    "setup:hooks": "node scripts/setup-git-hooks.mjs",
    "sync:global-css-doc": "node scripts/sync-global-css-doc.mjs"
  },
  "type": "module",
  "dependencies": {
    "@ark-ui/react": "^5.34.1",
    "@astrojs/check": "^0.9.2",
