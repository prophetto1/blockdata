    "@tailwindcss/vite": "^4.2.1",
    "astro": "^5.18.0",
    "fix-utf8": "^2.0.1",
    "lucide-react": "^0.577.0",
    "playwright": "^1.58.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rehype-katex": "^7.0.1",
    "remark-emoji": "^5.0.2",
    "remark-math": "^6.0.0",
