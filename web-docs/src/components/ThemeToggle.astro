---
type IconPath = {
  d: string;
  strokeLinecap?: 'round';
  strokeLinejoin?: 'round';
};

const Moon02Icon: readonly IconPath[] = [
  {
    d: 'M21.5 14.0784C20.3003 14.7189 18.9301 15.0821 17.4751 15.0821C12.7491 15.0821 8.91792 11.2509 8.91792 6.52485C8.91792 5.06986 9.28105 3.69968 9.92163 2.5C5.66765 3.49698 2.5 7.31513 2.5 11.8731C2.5 17.1899 6.8101 21.5 12.1269 21.5C16.6849 21.5 20.503 18.3324 21.5 14.0784Z',
    strokeLinecap: 'round',
    strokeLinejoin: 'round',
  },
];

const Sun03Icon: readonly IconPath[] = [
  {
    d: 'M17 12C17 14.7614 14.7614 17 12 17C9.23858 17 7 14.7614 7 12C7 9.23858 9.23858 7 12 7C14.7614 7 17 9.23858 17 12Z',
  },
  {
    d: 'M12 2V3.5M12 20.5V22M19.0708 19.0713L18.0101 18.0106M5.98926 5.98926L4.9286 4.9286M22 12H20.5M3.5 12H2M19.0713 4.92871L18.0106 5.98937M5.98975 18.0107L4.92909 19.0714',
    strokeLinecap: 'round',
  },
];
---

<button
  type="button"
  class="theme-toggle-button"
  data-theme-toggle
  aria-label="Toggle color scheme"
  title="Toggle color scheme"
>
  <span class="theme-toggle-icon theme-toggle-icon--light" aria-hidden="true">
    <svg fill="none" viewBox="0 0 24 24">
      {Sun03Icon.map((path) => (
        <path
          d={path.d}
          stroke="currentColor"
          stroke-linecap={path.strokeLinecap}
          stroke-linejoin={path.strokeLinejoin}
          stroke-width="1.5"
        />
      ))}
    </svg>
  </span>
  <span class="theme-toggle-icon theme-toggle-icon--dark" aria-hidden="true">
    <svg fill="none" viewBox="0 0 24 24">
      {Moon02Icon.map((path) => (
        <path
          d={path.d}
          stroke="currentColor"
          stroke-linecap={path.strokeLinecap}
          stroke-linejoin={path.strokeLinejoin}
          stroke-width="1.5"
        />
      ))}
    </svg>
  </span>
</button>

<script is:inline>
  (() => {
    const STORAGE_KEY = 'starlight-theme';

    const resolveTheme = () => {
      const rootTheme = document.documentElement.dataset.theme;
      if (rootTheme === 'light' || rootTheme === 'dark') return rootTheme;

      const storedTheme = window.localStorage.getItem(STORAGE_KEY);
      if (storedTheme === 'light' || storedTheme === 'dark') return storedTheme;
      if (storedTheme === 'system') {
        return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
      }

      return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
    };

    const applyTheme = (theme) => {
      document.documentElement.dataset.theme = theme;
      window.localStorage.setItem(STORAGE_KEY, theme);
    };

    const bindToggles = () => {
      document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
        if (button.dataset.themeToggleBound === 'true') return;

        button.dataset.themeToggleBound = 'true';
        button.addEventListener('click', () => {
          const currentTheme = resolveTheme();
          applyTheme(currentTheme === 'dark' ? 'light' : 'dark');
        });
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', bindToggles, { once: true });
    } else {
      bindToggles();
    }

    document.addEventListener('astro:page-load', bindToggles);
  })();
</script>

<style>
  .theme-toggle-button {
    display: inline-flex;
    width: 2rem;
    height: 2rem;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: 0.5rem;
    background: transparent;
    padding: 0;
    color: var(--sl-color-text);
    cursor: pointer;
    transition: background-color 150ms ease, color 150ms ease;
  }

  .theme-toggle-button:hover {
    background: color-mix(in oklab, var(--sl-color-accent) 14%, transparent);
    color: var(--sl-color-text);
  }

  .theme-toggle-button:focus-visible {
    outline: 2px solid var(--sl-color-text-accent);
    outline-offset: 2px;
  }

  .theme-toggle-icon {
    display: inline-flex;
    width: 1.25rem;
    height: 1.25rem;
    align-items: center;
    justify-content: center;
  }

  .theme-toggle-icon svg {
    width: 100%;
    height: 100%;
  }

  .theme-toggle-icon--dark {
    display: none;
  }

  :root[data-theme='light'] .theme-toggle-icon--light {
    display: none;
  }

  :root[data-theme='light'] .theme-toggle-icon--dark {
    display: inline-flex;
  }
</style>
