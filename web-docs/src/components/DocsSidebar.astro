---
import MobileMenuFooter from '@astrojs/starlight/components/MobileMenuFooter.astro';
import SidebarPersister from '@astrojs/starlight/components/SidebarPersister.astro';
import SidebarSublist from '@astrojs/starlight/components/SidebarSublist.astro';
import { PanelLeft } from 'lucide-react';

const { sidebar } = Astro.locals.starlightRoute;

// Split the unified sidebar into BlockData and AGChain sections.
// AGChain entries are identified by their top-level group label.
const AGCHAIN_LABEL = 'AGChain';


const blockdataSidebar = sidebar.filter(
  (entry) => !(entry.type === 'group' && entry.label === AGCHAIN_LABEL)
);
const agchainGroup = sidebar.find(
  (entry) => entry.type === 'group' && entry.label === AGCHAIN_LABEL
);
const agchainSidebar = agchainGroup?.type === 'group' ? agchainGroup.entries : [];

---

<script is:inline>
  (() => {
    try {
      const saved = localStorage.getItem('docs-sidebar-tab');
      if (saved === 'agchain' || saved === 'sections') {
        document.documentElement.setAttribute('data-sidebar-tab', saved);
      }
    } catch {}
  })();
</script>

<div class="docs-sidebar-shell" data-sidebar-view-root data-sidebar-view="nav">
  <div class="docs-sidebar-view-toggle" role="toolbar" aria-label="Sidebar view">
    <button
      type="button"
      class="docs-sidebar-view-toggle__button"
      data-sidebar-view-button
      data-sidebar-view-target="nav"
      aria-pressed="true"
      aria-label="BlockData"
      title="BlockData docs"
    >
      <PanelLeft className="docs-sidebar-view-toggle__icon" size={17} strokeWidth={2.35} aria-hidden="true" />
      <span class="docs-sidebar-view-toggle__label">BlockData</span>
    </button>
    <button
      type="button"
      class="docs-sidebar-view-toggle__button"
      data-sidebar-view-button
      data-sidebar-view-target="agchain"
      aria-pressed="false"
      aria-label="AGChain"
      title="AGChain docs"
    >
      <span class="docs-sidebar-view-toggle__label">AGChain</span>
    </button>
  </div>

  <script is:inline>
    (() => {
      const STORAGE_KEY = 'docs-sidebar-tab';

      function applySidebarView(root, view) {
        root.dataset.sidebarView = view;
        try { localStorage.setItem(STORAGE_KEY, view === 'agchain' ? 'agchain' : 'sections'); } catch {}
        root.querySelectorAll('[data-sidebar-view-button]').forEach((button) => {
          button.setAttribute(
            'aria-pressed',
            button.dataset.sidebarViewTarget === view ? 'true' : 'false'
          );
        });
      }

      document.querySelectorAll('[data-sidebar-view-root]').forEach((root) => {
        if (root.dataset.sidebarViewReady === 'true') return;
        root.dataset.sidebarViewReady = 'true';

        let saved = null;
        try { saved = localStorage.getItem(STORAGE_KEY); } catch {}
        const initialView = saved === 'agchain' ? 'agchain' : 'nav';
        applySidebarView(root, initialView);

        root.querySelectorAll('[data-sidebar-view-button]').forEach((button) => {
          button.addEventListener('click', () => {
            const nextView = button.dataset.sidebarViewTarget === 'agchain' ? 'agchain' : 'nav';
            applySidebarView(root, nextView);
          });
        });
      });
    })();
  </script>

  <div data-sidebar-panel="nav">
    <div class="docs-sidebar-scroll">
      <SidebarPersister>
        <SidebarSublist sublist={blockdataSidebar} />
      </SidebarPersister>
    </div>
  </div>

  <div data-sidebar-panel="agchain">
    <div class="docs-sidebar-scroll">
      {agchainSidebar.length === 0 ? (
        <p style="padding: 1rem; color: var(--muted-foreground); font-size: 0.8rem;">No AGChain docs found.</p>
      ) : (
        <SidebarSublist sublist={agchainSidebar} />
      )}
    </div>
  </div>
</div>

<div class="md:sl-hidden">
  <MobileMenuFooter />
</div>

<style>
  @layer starlight.core {
    .docs-sidebar-shell {
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
      height: 100%;
      min-height: 0;
    }

    .docs-sidebar-view-toggle {
      flex-shrink: 0;
      display: flex;
      gap: 0;
      border-bottom: 1px solid var(--separator);
      margin-inline: calc(-1 * var(--sl-sidebar-pad-x, 1rem));
      padding-inline: var(--sl-sidebar-pad-x, 1rem);
    }

    .docs-sidebar-view-toggle__button {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.35rem;
      border: 0;
      border-radius: 0;
      background: transparent;
      height: 2.25rem;
      padding: 0 0.5rem;
      color: var(--muted-foreground);
      cursor: pointer;
      font-family: inherit;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.02em;
      text-transform: uppercase;
      transition: color 100ms ease;
    }

    .docs-sidebar-view-toggle__button:hover {
      color: var(--sl-color-text);
    }

    :global(.docs-sidebar-view-toggle__icon) {
      display: block;
      opacity: 0.92;
    }

    .docs-sidebar-view-toggle__label {
      white-space: nowrap;
    }

    .docs-sidebar-view-toggle__button[aria-pressed='true'] {
      color: var(--sl-color-text);
    }

    .docs-sidebar-view-toggle__button[aria-pressed='true']::after {
      content: '';
      position: absolute;
      bottom: -1px;
      left: 0;
      right: 0;
      height: 1px;
      background: var(--sl-color-text);
    }

    .docs-sidebar-view-toggle__button:focus-visible {
      outline: 1px solid var(--ring);
      outline-offset: -1px;
    }

    /* Panel visibility */
    [data-sidebar-view-root][data-sidebar-view='nav'] [data-sidebar-panel='agchain'] {
      display: none;
    }

    [data-sidebar-view-root][data-sidebar-view='agchain'] [data-sidebar-panel='nav'] {
      display: none;
    }

    [data-sidebar-panel='nav'],
    [data-sidebar-panel='agchain'] {
      display: flex;
      flex-direction: column;
      flex: 1;
      min-height: 0;
    }

    :global(.docs-sidebar-scroll) {
      flex: 1;
      min-height: 0;
      overflow-y: auto;
      overflow-x: hidden;
    }
  }
</style>
