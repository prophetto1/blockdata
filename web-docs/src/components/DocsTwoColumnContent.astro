---
import { extname } from 'node:path';
import { getCurrentDocsRelativePath, getDocsHrefFromRelativePath } from '../lib/docs/content-tree.mjs';

const { toc, entry } = Astro.locals.starlightRoute;
const currentRelativePath = entry?.filePath ? getCurrentDocsRelativePath(entry.filePath) : '';
const currentFileExtension = currentRelativePath ? extname(currentRelativePath).toLowerCase() : '';
const currentDocsHref = currentRelativePath ? getDocsHrefFromRelativePath(currentRelativePath) : '';
---

{/* ContentWorkAreaShell
    Sections mode: standard Starlight article (TOC + main pane).
    Filetree mode: editor-only workbench.
    The normal docs page remains the preview surface for the app. */}

<div class="content-work-area lg:sl-flex">
  {toc && (
    <aside class="right-sidebar-container print:hidden">
      <div class="right-sidebar">
        <div class="right-sidebar-scroll">
          <slot name="right-sidebar" />
        </div>
      </div>
    </aside>
  )}

  {/* Filetree mode only. Owns the editor workbench surface. */}
  <div class="wa-workbench-host" data-workbench-root>
    <div class="wa-workbench-loading">Loading workspace...</div>
  </div>

  {/* Sections-mode main pane. In filetree mode this remains hidden rather than
      being adopted into a dedicated preview shell. */}
  <div
    class="wa-preview"
    data-shell="preview-column"
    data-current-file-path={currentRelativePath || undefined}
    data-current-file-extension={currentFileExtension || undefined}
    data-current-docs-href={currentDocsHref || undefined}
  >
    <slot />
  </div>
</div>

<script>
  import { mountWorkbenchWhenFiletreeMode } from '../lib/docs/lazy-shell-mount';

  mountWorkbenchWhenFiletreeMode('[data-workbench-root]');
</script>

<style>
  @layer starlight.core {
    .wa-preview {
      isolation: isolate;
    }

    .wa-workbench-host {
      display: none;
    }

    :global(.wa-splitter) {
      display: none;
    }

    @media (min-width: 72rem) {
      .right-sidebar-container {
        order: 2;
        position: relative;
        width: calc(
          var(--sl-sidebar-width) + (100% - var(--sl-content-width) - var(--sl-sidebar-width)) / 2
        );
      }

      .right-sidebar {
        position: fixed;
        top: 0;
        border-inline-start: 1px solid var(--sl-color-hairline);
        padding-top: var(--sl-nav-height);
        width: 100%;
        height: 100vh;
      }

      :global(.right-sidebar-scroll) {
        height: 100%;
        overflow-y: auto;
        overflow-x: hidden;
      }

      :global(:not([data-shell-mode='filetree'])) .wa-preview {
        width: 100%;
      }

      :global([data-has-sidebar][data-has-toc]:not([data-shell-mode='filetree'])) .wa-preview {
        --sl-content-margin-inline: auto 0;
        order: 1;
        width: calc(
          var(--sl-content-width) + (100% - var(--sl-content-width) - var(--sl-sidebar-width)) / 2
        );
      }
    }

    :global([data-shell-mode='filetree']) .right-sidebar-container {
      display: none;
    }

    :global([data-shell-mode='filetree']) .content-work-area {
      display: flex !important;
      flex-direction: column;
      height: calc(100vh - var(--sl-nav-height, 3.5rem));
      overflow: hidden;
    }

    :global([data-shell-mode='filetree']) .wa-workbench-host {
      display: flex;
      flex: 1;
      min-height: 0;
    }

    :global([data-shell-mode='filetree']) :global(.wa-splitter) {
      display: flex;
      flex: 1;
      min-height: 0;
    }

    :global([data-shell-mode='filetree']) .wa-preview {
      display: none;
    }
  }
</style>
