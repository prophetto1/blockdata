---
import EditorTabStrip from './EditorTabStrip.tsx';
import SplitEditorView from './SplitEditorView.tsx';

const { toc } = Astro.locals.starlightRoute;
---

{/* ═══════════════════════════════════════════════════════════
    ContentWorkAreaShell
    ═══════════════════════════════════════════════════════════
    Sole owner of the content-area layout contract.

    Sections mode: standard Starlight article (TOC + main-pane).
    Filetree mode: five contracted sub-shells:

      ┌─────────────────────────────────────────────────────┐
      │ WorkAreaStripShell (row 1, col 1/-1)                │
      │  ┌─ EditorTabShell ─┐   ┌─ PreviewHeaderShell ──┐  │
      │  │ Source | Rich    │ │ │ Preview                │  │
      │  └──────────────────┘   └────────────────────────┘  │
      ├─────────────────────┬─┬─────────────────────────────┤
      │ EditorColumnShell   │D│ PreviewColumnShell          │
      │ (row 2, col 1)      │i│ (row 2, col 3)             │
      │                     │v│                             │
      │  ┌SourceSurface ──┐ │i│  ┌ Astro <slot/> ────────┐ │
      │  │ Monaco editor  │ │d│  │ Same rendering path.   │ │
      │  └────────────────┘ │e│  │ No second renderer.    │ │
      │  ┌RichSurface ────┐ │r│  └───────────────────────-┘ │
      │  │ MDXEditor      │ │ │                             │
      │  └────────────────┘ │ │                             │
      └─────────────────────┴─┴─────────────────────────────┘

    Grid authority: .content-work-area owns --split-editor-pct.
    All sub-shells derive column sizing from the parent grid.
    The divider is the sole resize authority.
    ═══════════════════════════════════════════════════════════ */}

<div class="content-work-area lg:sl-flex">

  {/* ── Sections mode: right sidebar (TOC) ── */}
  {toc && (
    <aside class="right-sidebar-container print:hidden">
      <div class="right-sidebar">
        <slot name="right-sidebar" />
      </div>
    </aside>
  )}

  {/* ── WorkAreaStripShell ──
       Row 1, spans all columns.
       Contains EditorTabShell (col 1) and PreviewHeaderShell (col 3). */}
  <div class="wa-strip" data-shell="work-area-strip">
    <EditorTabStrip client:load />
    <div class="wa-strip__preview-header" data-shell="preview-header">
      <span class="wa-strip__label">Preview</span>
    </div>
  </div>

  {/* ── EditorColumnShell ──
       Row 2, col 1. Contains the active editor surface.
       SplitEditorView switches between Source and Rich (MDXEditor). */}
  <div class="wa-editor" data-shell="editor-column">
    <SplitEditorView client:load />
  </div>

  {/* ── Divider ──
       Row 2, col 2. Sole resize authority.
       Updates --split-editor-pct on the parent grid. */}
  <div class="wa-divider" data-shell="divider" data-resize-divider></div>

  {/* ── PreviewColumnShell ──
       Row 2, col 3. Contains the Astro-rendered article.
       Same <slot/>, same rendering path. No second renderer.
       In Sections mode this is the normal main-pane. */}
  <div class="wa-preview" data-shell="preview-column">
    <slot />
  </div>
</div>

<script is:inline>
  (() => {
    // Canonical source: src/lib/docs/shell-state.ts
    // Duplicated here because is:inline scripts cannot import ES modules.
    const FILE_STORAGE_KEY = 'shell-selected-file';      // FILE_STORAGE_KEY
    const PREVIEW_REFRESH_EVENT = 'shell-preview-refresh'; // SHELL_PREVIEW_REFRESH_EVENT
    const FILE_SELECT_EVENT = 'shell-file-select';        // SHELL_FILE_EVENT
    const FILE_RESET_EVENT = 'shell-file-reset';          // SHELL_FILE_RESET_EVENT
    const SPLIT_RATIO_KEY = 'shell-split-ratio';          // SPLIT_RATIO_STORAGE_KEY
    const PREVIEW_REFRESH_QUERY = '_shell_preview';

    function escapeHtml(raw) {
      return String(raw)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function renderInlineMarkdown(raw) {
      return escapeHtml(raw).replace(/`([^`]+)`/g, '<code>$1</code>');
    }

    function renderLocalMarkdown(raw, extension) {
      const lines = String(raw ?? '').replace(/\r\n?/g, '\n').split('\n');
      const blocks = [];
      let inCode = false;
      let inList = false;
      let paragraph = [];

      function closeParagraph() {
        if (!paragraph.length) return;
        blocks.push(`<p>${paragraph.join(' ')}</p>`);
        paragraph = [];
      }

      function closeList() {
        if (!inList) return;
        blocks.push('</ul>');
        inList = false;
      }

      for (const line of lines) {
        if (line.startsWith('```')) {
          if (inCode) {
            blocks.push('</code></pre>');
            inCode = false;
            continue;
          }
          closeParagraph();
          closeList();
          blocks.push('<pre><code>');
          inCode = true;
          continue;
        }

        if (inCode) {
          blocks.push(escapeHtml(line));
          continue;
        }

        if (/^#{1,6}\s+/.test(line)) {
          closeParagraph();
          closeList();
          const level = line.match(/^(#{1,6})\s+/)?.[1]?.length ?? 1;
          blocks.push(`<h${level}>${renderInlineMarkdown(line.replace(/^(#{1,6})\s+/, ''))}</h${level}>`);
          continue;
        }

        if (/^>\s?/.test(line)) {
          closeParagraph();
          closeList();
          blocks.push(`<blockquote>${renderInlineMarkdown(line.replace(/^>\s?/, ''))}</blockquote>`);
          continue;
        }

        if (/^[-*]\s+/.test(line)) {
          if (!inList) {
            closeParagraph();
            blocks.push('<ul>');
            inList = true;
          }
          blocks.push(`<li>${renderInlineMarkdown(line.replace(/^[-*]\s+/, ''))}</li>`);
          continue;
        }

        if (!line.trim()) {
          closeParagraph();
          closeList();
          continue;
        }

        paragraph.push(renderInlineMarkdown(line.trim()));
      }

      closeParagraph();
      closeList();
      if (inCode) blocks.push('</code></pre>');

      const variant = extension === '.mdx' ? 'split-editor__local-preview--mdx' : '';
      return `<article class="split-editor__local-preview ${variant}">${blocks.join('')}</article>`;
    }

    function refreshRepoPreview() {
      const current = new URL(window.location.href);
      current.searchParams.set(PREVIEW_REFRESH_QUERY, String(Date.now()));
      window.location.replace(current.toString());
    }

    function updateLocalPreview(detail) {
      const preview = document.querySelector('[data-shell=\"preview-column\"]');
      if (!preview) return;
      preview.innerHTML = renderLocalMarkdown(detail?.content ?? '', detail?.extension ?? '');
    }

    // ── Divider: sole resize authority ──
    const divider = document.querySelector('[data-resize-divider]');
    if (divider) {
      const workArea = divider.closest('.content-work-area');
      let dragging = false;

      divider.addEventListener('pointerdown', (e) => {
        e.preventDefault();
        dragging = true;
        divider.setPointerCapture(e.pointerId);
        document.documentElement.style.cursor = 'col-resize';
        document.documentElement.style.userSelect = 'none';
      });

      window.addEventListener('pointermove', (e) => {
        if (!dragging || !workArea) return;
        const rect = workArea.getBoundingClientRect();
        const pct = ((e.clientX - rect.left) / rect.width) * 100;
        const clamped = Math.max(20, Math.min(80, pct));
        workArea.style.setProperty('--split-editor-pct', clamped + '%');
        try { localStorage.setItem(SPLIT_RATIO_KEY, String(clamped)); } catch {}
      });

      window.addEventListener('pointerup', () => {
        if (!dragging) return;
        dragging = false;
        document.documentElement.style.cursor = '';
        document.documentElement.style.userSelect = '';
      });

      // Restore saved ratio
      try {
        const saved = localStorage.getItem(SPLIT_RATIO_KEY);
        if (saved && workArea) {
          const pct = parseFloat(saved);
          if (pct >= 20 && pct <= 80) {
            workArea.style.setProperty('--split-editor-pct', pct + '%');
          }
        }
      } catch {}
    }

    // ── File selection: persist and navigate ──
    window.addEventListener(FILE_SELECT_EVENT, (e) => {
      const detail = e.detail;
      if (!detail?.filePath) return;
      try { sessionStorage.setItem(FILE_STORAGE_KEY, JSON.stringify(detail)); } catch {}
      if (detail.sourceKind === 'local') {
        const preview = document.querySelector('[data-shell=\"preview-column\"]');
        if (preview) {
          preview.innerHTML = '<div class="split-editor__loading">Loading local preview...</div>';
        }
        return;
      }

      if (detail.docsHref) {
        const next = new URL(detail.docsHref, window.location.origin);
        next.searchParams.set(PREVIEW_REFRESH_QUERY, String(Date.now()));
        window.location.replace(next.toString());
      }
    });

    // ── Preview refresh after save ──
    window.addEventListener(PREVIEW_REFRESH_EVENT, (event) => {
      if (event.detail?.sourceKind === 'local') {
        updateLocalPreview(event.detail);
        return;
      }
      refreshRepoPreview();
    });

    window.addEventListener(FILE_RESET_EVENT, (event) => {
      const reason = event.detail?.reason;
      if (reason !== 'folder-cleared' && reason !== 'file-missing') return;

      const preview = document.querySelector('[data-shell=\"preview-column\"]');
      if (!preview) return;

      preview.innerHTML = '<div class="split-editor__loading">Select a file from the tree</div>';
    });
  })();
</script>

<style>
  @layer starlight.core {

    /* ═══════════════════════════════════════════════════════
       ContentWorkAreaShell — grid authority
       ═══════════════════════════════════════════════════════ */

    .content-work-area {
      --split-editor-pct: 50%;
    }

    /* ── Sections mode (default) ──
       Hide all filetree sub-shells.
       wa-preview acts as the normal main-pane. */

    .wa-preview {
      isolation: isolate;
    }

    .wa-strip,
    .wa-editor,
    .wa-divider {
      display: none;
    }

    @media (min-width: 72rem) {
      .right-sidebar-container {
        order: 2;
        position: relative;
        width: calc(
          var(--sl-sidebar-width) + (100% - var(--sl-content-width) - var(--sl-sidebar-width)) / 2
        );
      }

      .right-sidebar {
        position: fixed;
        top: 0;
        border-inline-start: 1px solid var(--sl-color-hairline);
        padding-top: var(--sl-nav-height);
        width: 100%;
        height: 100vh;
        overflow-y: auto;
        scrollbar-width: none;
      }

      /* Sections-mode only — scoped so they don't fight filetree grid */
      :global(:not([data-shell-mode='filetree'])) .wa-preview {
        width: 100%;
      }

      :global([data-has-sidebar][data-has-toc]:not([data-shell-mode='filetree'])) .wa-preview {
        --sl-content-margin-inline: auto 0;
        order: 1;
        width: calc(
          var(--sl-content-width) + (100% - var(--sl-content-width) - var(--sl-sidebar-width)) / 2
        );
      }
    }

    /* ═══════════════════════════════════════════════════════
       Filetree mode — activate all sub-shells
       ═══════════════════════════════════════════════════════ */

    :global([data-shell-mode='filetree']) .right-sidebar-container {
      display: none;
    }

    /* Parent grid: single sizing authority.
       Columns: editor | divider | preview
       Rows: strip | content */
    :global([data-shell-mode='filetree']) .content-work-area {
      display: grid !important; /* override lg:sl-flex */
      grid-template-columns: var(--split-editor-pct) 4px 1fr;
      grid-template-rows: auto 1fr;
      height: calc(100vh - var(--sl-nav-height, 3.5rem));
      overflow: hidden;
    }

    /* ── WorkAreaStripShell ──
       Row 1, spans all 3 columns.
       Internal grid mirrors parent columns so tab areas align. */
    :global([data-shell-mode='filetree']) .wa-strip {
      display: grid;
      grid-column: 1 / -1;
      grid-row: 1;
      grid-template-columns: subgrid;
      border-bottom: 1px solid var(--separator, var(--sl-color-hairline));
      height: 2.25rem;
    }

    /* ── EditorTabShell ── (strip col 1) */
    .wa-strip__editor-tabs {
      grid-column: 1;
      display: flex;
      align-items: center;
      padding: 0 0.75rem;
    }

    /* ── PreviewHeaderShell ── (strip col 3) */
    .wa-strip__preview-header {
      grid-column: 3;
      display: flex;
      align-items: center;
      padding: 0 0.75rem;
      border-inline-start: 1px solid var(--separator, var(--sl-color-hairline));
    }

    /* ── EditorColumnShell ── (row 2, col 1) */
    :global([data-shell-mode='filetree']) .wa-editor {
      display: flex;
      flex-direction: column;
      grid-row: 2;
      grid-column: 1;
      min-height: 0;
      overflow: hidden;
      background: var(--sl-color-bg);
    }

    /* ── Divider ── (row 2, col 2) */
    :global([data-shell-mode='filetree']) .wa-divider {
      display: block;
      grid-row: 2;
      grid-column: 2;
      background: var(--separator, var(--sl-color-hairline));
      cursor: col-resize;
      transition: background-color 120ms ease;
    }

    :global([data-shell-mode='filetree']) .wa-divider:hover {
      background: var(--sl-color-text-accent);
    }

    /* ── PreviewColumnShell ── (row 2, col 3)
       Same Astro-rendered content. No second renderer. */
    :global([data-shell-mode='filetree']) .wa-preview {
      grid-row: 2;
      grid-column: 3;
      order: unset;
      min-height: 0;
      overflow-y: auto;
      width: 100% !important; /* override Sections-mode calc */
    }

    /* ═══════════════════════════════════════════════════════
       Tab styling — shared across EditorTabShell
       ═══════════════════════════════════════════════════════ */

    .wa-strip__tab {
      position: relative;
      display: flex;
      align-items: center;
      gap: 0.35rem;
      border: 0;
      background: transparent;
      padding: 0.4rem 0.65rem;
      color: var(--muted-foreground);
      font-family: var(--app-font-sans);
      font-size: 0.75rem;
      font-weight: 600;
      cursor: pointer;
      transition: color 100ms ease;
    }

    .wa-strip__tab:hover {
      color: var(--sl-color-text);
    }

    .wa-strip__tab[aria-pressed='true'] {
      color: var(--sl-color-text);
    }

    .wa-strip__tab[aria-pressed='true']::after {
      content: '';
      position: absolute;
      bottom: -1px;
      left: 0;
      right: 0;
      height: 1px;
      background: var(--sl-color-text);
    }

    .wa-strip__label {
      color: var(--muted-foreground);
      font-family: var(--app-font-sans);
      font-size: 0.75rem;
      font-weight: 600;
    }
  }
</style>
