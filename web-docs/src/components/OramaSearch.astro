---
---

<orama-search>
  <button
    data-open-modal
    disabled
    aria-label="Search"
    aria-keyshortcuts="Control+K"
  >
    <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <span class="sl-hidden md:sl-block" aria-hidden="true">Search</span>
    <kbd class="sl-hidden md:sl-flex" style="display: none;">
      <kbd>Ctrl</kbd><kbd>K</kbd>
    </kbd>
  </button>

  <dialog style="padding:0" aria-label="Search">
    <div class="dialog-frame sl-flex">
      <button data-close-modal class="sl-flex md:sl-hidden">Cancel</button>
      {
        import.meta.env.DEV ? (
          <div class="dev-warning" dir="ltr">
            <p>Search is available in production builds.<br />Run <code>npm run build && npm run preview</code> to test.</p>
          </div>
        ) : (
          <div id="orama-search-root" />
        )
      }
    </div>
  </dialog>
</orama-search>

{/* Inline script for platform key detection — avoids flash of wrong shortcut */}
<script is:inline>
  (() => {
    const openBtn = document.querySelector('orama-search button[data-open-modal]');
    const shortcut = openBtn?.querySelector('kbd');
    if (!openBtn || !(shortcut instanceof HTMLElement)) return;
    const platformKey = shortcut.querySelector('kbd');
    if (platformKey && /(Mac|iPhone|iPod|iPad)/i.test(navigator.platform)) {
      platformKey.textContent = '\u2318';
      openBtn.setAttribute('aria-keyshortcuts', 'Meta+K');
    }
    shortcut.style.display = '';
  })();
</script>

<script>
  class OramaSearchElement extends HTMLElement {
    private reactRoot: import('react-dom/client').Root | null = null;

    constructor() {
      super();

      const openBtn = this.querySelector<HTMLButtonElement>('button[data-open-modal]')!;
      const closeBtn = this.querySelector<HTMLButtonElement>('button[data-close-modal]')!;
      const dialog = this.querySelector('dialog')!;
      const dialogFrame = this.querySelector('.dialog-frame')!;

      const onClick = (event: MouseEvent) => {
        const isLink = 'href' in (event.target || {});
        if (
          isLink ||
          (document.body.contains(event.target as Node) &&
            !dialogFrame.contains(event.target as Node))
        ) {
          closeModal();
        }
      };

      const mountSearch = async () => {
        if (this.reactRoot || import.meta.env.DEV) return;
        const [{ createElement }, { createRoot }, { default: OramaSearchPanel }] = await Promise.all(
          [
            import('react'),
            import('react-dom/client'),
            import('./OramaSearchPanel'),
          ]
        );
        const container = this.querySelector('#orama-search-root')!;
        this.reactRoot = createRoot(container);
        this.reactRoot.render(createElement(OramaSearchPanel));
      };

      const openModal = (event?: MouseEvent) => {
        dialog.showModal();
        document.body.toggleAttribute('data-search-modal-open', true);
        mountSearch();
        // Focus will be handled by the React component's autoFocus
        event?.stopPropagation();
        window.addEventListener('click', onClick);
      };

      const closeModal = () => dialog.close();

      openBtn.addEventListener('click', openModal);
      openBtn.disabled = false;
      closeBtn.addEventListener('click', closeModal);

      dialog.addEventListener('close', () => {
        document.body.toggleAttribute('data-search-modal-open', false);
        window.removeEventListener('click', onClick);
      });

      // Ctrl/Cmd+K keyboard shortcut
      window.addEventListener('keydown', (e) => {
        if ((e.metaKey === true || e.ctrlKey === true) && e.key === 'k') {
          dialog.open ? closeModal() : openModal();
          e.preventDefault();
        }
      });
    }
  }

  customElements.define('orama-search', OramaSearchElement);
</script>

<style>
  @layer starlight.core {
    orama-search {
      display: contents;
    }

    button[data-open-modal] {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      border: 0;
      background-color: transparent;
      color: var(--sl-color-gray-1);
      cursor: pointer;
      height: 2.5rem;
      font-size: var(--sl-text-xl);
    }

    @media (min-width: 50rem) {
      button[data-open-modal] {
        border: 1px solid var(--sl-color-gray-5);
        border-radius: 0.5rem;
        padding-inline-start: 0.75rem;
        padding-inline-end: 0.5rem;
        background-color: var(--sl-color-black);
        color: var(--sl-color-gray-2);
        font-size: var(--sl-text-sm);
        width: 100%;
        max-width: 22rem;
      }
      button[data-open-modal]:hover {
        border-color: var(--sl-color-gray-2);
        color: var(--sl-color-white);
      }
      button[data-open-modal] > :last-child {
        margin-inline-start: auto;
      }
    }

    button > kbd {
      border-radius: 0.25rem;
      font-size: var(--sl-text-2xs);
      gap: 0.25em;
      padding-inline: 0.375rem;
      background-color: var(--sl-color-gray-6);
    }

    kbd {
      font-family: var(--__sl-font);
    }

    dialog {
      margin: 0;
      background-color: var(--sl-color-gray-6);
      border: 1px solid var(--sl-color-gray-5);
      width: 100%;
      max-width: 100%;
      height: 100%;
      max-height: 100%;
      box-shadow: var(--sl-shadow-lg);
    }
    dialog[open] {
      display: flex;
    }

    dialog::backdrop {
      background-color: var(--sl-color-backdrop-overlay);
      -webkit-backdrop-filter: blur(0.25rem);
      backdrop-filter: blur(0.25rem);
    }

    .dialog-frame {
      position: relative;
      overflow: auto;
      flex-direction: column;
      flex-grow: 1;
      gap: 1rem;
      padding: 1rem;
    }

    button[data-close-modal] {
      position: absolute;
      z-index: 1;
      align-items: center;
      align-self: flex-end;
      height: 2.5rem;
      padding: 0.25rem;
      border: 0;
      background: transparent;
      cursor: pointer;
      color: var(--sl-color-text-accent);
    }

    .dev-warning {
      margin: auto;
      text-align: center;
      color: var(--sl-color-gray-2);
    }
    .dev-warning code {
      font-size: var(--sl-text-sm);
      background: var(--sl-color-gray-5);
      padding: 0.15em 0.4em;
      border-radius: 0.25rem;
    }

    @media (min-width: 50rem) {
      dialog {
        margin: 4rem auto auto;
        border-radius: 0.5rem;
        width: 90%;
        max-width: 40rem;
        height: max-content;
        min-height: 15rem;
        max-height: calc(100% - 8rem);
      }

      .dialog-frame {
        padding: 1.5rem;
      }
    }
  }
</style>

<style is:global>
  @layer starlight.core {
    [data-search-modal-open] {
      overflow: hidden;
    }

    .orama-panel {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      width: 100%;
    }

    .orama-input-wrap {
      position: relative;
      display: flex;
      align-items: center;
    }

    .orama-search-icon {
      position: absolute;
      inset-inline-start: 0.75rem;
      color: var(--sl-color-gray-3);
      pointer-events: none;
    }

    .orama-input {
      width: 100%;
      padding: 0.625rem 0.75rem 0.625rem 2.5rem;
      border: 1px solid var(--sl-color-gray-5);
      border-radius: 0.375rem;
      background: var(--sl-color-black);
      color: var(--sl-color-white);
      font-size: 1rem;
      font-family: var(--__sl-font);
      outline: none;
    }
    .orama-input:focus {
      border-color: var(--sl-color-accent);
    }
    .orama-input::placeholder {
      color: var(--sl-color-gray-3);
    }

    .orama-status {
      text-align: center;
      color: var(--sl-color-gray-3);
      font-size: var(--sl-text-sm);
      padding: 1rem 0;
      margin: 0;
    }

    .orama-results {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 1px;
    }

    .orama-result a {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      padding: 0.75rem 1rem;
      border-radius: 0.375rem;
      background: var(--sl-color-black);
      text-decoration: none;
      color: var(--sl-color-gray-2);
      transition: outline 100ms ease;
    }
    .orama-result a:hover,
    .orama-result a:focus-visible {
      outline: 1px solid var(--sl-color-accent-high);
      background: var(--sl-color-accent-low);
    }

    .orama-result-title {
      color: var(--sl-color-white);
      font-weight: 600;
      font-size: var(--sl-text-body);
    }

    .orama-result-excerpt {
      font-size: var(--sl-text-sm);
      color: var(--sl-color-gray-3);
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }
  }
</style>
