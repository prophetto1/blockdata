{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Blockdata",
  "theme": "mint",
  "description": "Documentation for the Blockdata platform — schema-driven structured extraction, pipeline orchestration, and data management.",
  "logo": {
    "light": "/images/logo-light.png",
    "dark": "/images/logo-dark.png",
    "href": "https://blockdata.mintlify.app"
  },
  "favicon": "/images/favicon.ico",
  "colors": {
    "primary": "#EB5E41",
    "light": "#F07D65",
    "dark": "#D94E32",
    "background": {
      "dark": "#0e0e0e",
      "light": "#faf9f7"
    }
  },
  "appearance": {
    "default": "dark"
  },
  "fonts": {
    "body": {
      "family": "IBM Plex Sans"
    },
    "heading": {
      "family": "IBM Plex Sans"
    },
    "code": {
      "family": "JetBrains Mono"
    }
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": "system"
  },
  "icons": {
    "library": "lucide"
  },
  "search": {
    "prompt": "Search docs..."
  },
  "seo": {
    "indexing": "all"
  },
  "metadata": {
    "timestamp": true
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Internal Guides",
        "icon": "book-open",
        "groups": [
          {
            "group": "Infrastructure",
            "icon": "server",
            "pages": [
              "s",
              "edge-functions"
            ]
          },
          {
            "group": "Frontend",
            "icon": "layout",
            "pages": [
              "frontend/app-shell",
              "frontend/design-system"
            ]
          },
          {
            "group": "Plans",
            "icon": "clipboard-list",
            "pages": [
              "plans/services-scalability-plan"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "App",
        "href": "https://blockdata.run"
      }
    ]
  }
}