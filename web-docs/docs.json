{
    "$schema":  "https://mintlify.com/docs.json",
    "name":  "Blockdata",
    "theme":  "mint",
    "description":  "Documentation for the Blockdata platform — schema-driven structured extraction, pipeline orchestration, and data management.",
    "logo":  {
                 "light":  "/images/logo-light.svg",
                 "dark":  "/images/logo-dark.svg",
                 "href":  "/"
             },
    "favicon":  "/images/favicon.ico",
    "colors":  {
                   "primary":  "#EB5E41",
                   "light":  "#F07D65",
                   "dark":  "#D94E32"
               },
    "appearance":  {
                       "default":  "dark"
                   },
    "fonts":  {
                  "body":  {
                               "family":  "IBM Plex Sans"
                           },
                  "heading":  {
                                  "family":  "IBM Plex Sans"
                              }
              },
    "styling":  {
                    "eyebrows":  "breadcrumbs",
                    "codeblocks":  "system"
                },
    "icons":  {
                  "library":  "lucide"
              },
    "search":  {
                   "prompt":  "Search docs..."
               },
    "seo":  {
                "indexing":  "all"
            },
    "metadata":  {
                     "timestamp":  true
                 },
    "navigation":  {
                       "groups":  [
                                      {
                                          "group":  "Infrastructure",
                                          "pages":  [
                                                        "s",
                                                        "edge-functions",
                                                        "infrastructure/plugin-registry",
                                                        "infrastructure/eyecite-reference"
                                                    ]
                                      },
                                      {
                                          "group":  "Frontend",
                                          "pages":  [
                                                        "frontend/app-shell",
                                                        "frontend/design-system"
                                                    ]
                                      },
                                      {
                                          "group":  "Plans",
                                          "pages":  [
                                                        "plans/services-scalability-plan",
                                                        "plans/edge-to-fastapi-migration",
                                                        "plans/execution-system"
                                                    ]
                                      }
                                  ]
                   },
    "navbar":  {
                   "links":  [
                                 {
                                     "label":  "App",
                                     "href":  "https://blockdata.run"
                                 }
                             ]
               }
}
