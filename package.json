{
  "name": "writing-system",
  "private": true,
  "workspaces": [
    "web",
    "web-docs"
  ],
  "scripts": {
    "capture-server": "node scripts/capture/capture-server.mjs",
    "paths:normalize": "node scripts/path-normalizer/normalize-hardcoded-paths.mjs",
    "platform-api:dev": "powershell -ExecutionPolicy Bypass -File scripts/start-platform-api.ps1 -NoReload",
    "platform-api:recover": "powershell -ExecutionPolicy Bypass -File scripts/platform-api-dev-control.ps1 -Action recover",
    "test:hardcoded-paths": "node --test scripts/path-normalizer/tests/normalize-hardcoded-paths.test.mjs",
    "test:supabase-extension-replay-guardrails": "node --test scripts/tests/supabase-extension-replay-guardrails.test.mjs",
    "test:workflow-guardrails": "node --test scripts/tests/supabase-db-workflows.test.mjs",
    "test:supabase-migration-reconciliation-contract": "node --test scripts/tests/supabase-migration-reconciliation-contract.test.mjs"
  },
  "dependencies": {
    "pg": "^8.19.0"
  },
  "devDependencies": {
    "mintlify": "^4.2.391",
    "zod": "^3.25.76"
  }
}
