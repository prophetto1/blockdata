{
  "type": "object",
  "required": [
    "basics",
    "skills",
    "experience"
  ],
  "properties": {
    "basics": {
      "type": "object",
      "required": [
        "name",
        "email"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "The full name of the candidate"
        },
        "email": {
          "type": "string",
          "description": "The email address of the candidate"
        },
        "phone": {
          "type": "string",
          "description": "The phone number of the candidate in any standard format"
        },
        "location": {
          "type": "object",
          "description": "The current location of the candidate",
          "properties": {
            "city": {
              "type": "string",
              "description": "The city where the candidate is located"
            },
            "region": {
              "type": "string",
              "description": "State or province of the candidate"
            },
            "country": {
              "type": "string",
              "description": "Country where the candidate is located"
            }
          }
        },
        "profiles": {
          "type": "array",
          "description": "Professional social media profiles or personal websites",
          "items": {
            "type": "object",
            "properties": {
              "network": {
                "type": "string",
                "description": "Name of the social network (e.g., LinkedIn, GitHub)"
              },
              "url": {
                "type": "string",
                "description": "Full URL to the profile"
              }
            }
          }
        },
        "summary": {
          "type": "string",
          "description": "Brief professional summary or objective statement"
        }
      }
    },
    "skills": {
      "type": "array",
      "description": "Technical and professional skills grouped by category",
      "items": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string",
            "description": "Skill category (e.g., Programming Languages, Tools, Soft Skills)"
          },
          "keywords": {
            "type": "array",
            "description": "List of specific skills within the category",
            "items": {
              "type": "string"
            }
          },
          "level": {
            "type": "string",
            "enum": [
              "beginner",
              "intermediate",
              "advanced",
              "expert"
            ],
            "description": "Proficiency level in this skill category"
          }
        }
      }
    },
    "experience": {
      "type": "array",
      "description": "Professional work experience in reverse chronological order",
      "items": {
        "type": "object",
        "required": [
          "company",
          "position",
          "startDate"
        ],
        "properties": {
          "company": {
            "type": "string",
            "description": "Name of the employer or company"
          },
          "position": {
            "type": "string",
            "description": "Job title or role"
          },
          "startDate": {
            "type": "string",
            "description": "Start date of employment (YYYY-MM or YYYY-MM-DD)"
          },
          "endDate": {
            "type": "string",
            "description": "End date of employment (YYYY-MM or YYYY-MM-DD), or 'Present' if current"
          },
          "highlights": {
            "type": "array",
            "description": "Key achievements, responsibilities, or contributions",
            "items": {
              "type": "string"
            }
          },
          "technologies": {
            "type": "array",
            "description": "Technical tools, languages, or frameworks used in this role",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "institution",
          "degree"
        ],
        "properties": {
          "institution": {
            "type": "string"
          },
          "degree": {
            "type": "string"
          },
          "field": {
            "type": "string"
          },
          "graduationDate": {
            "type": "string"
          },
          "gpa": {
            "type": "number"
          }
        }
      }
    },
    "certifications": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "issuer": {
            "type": "string"
          },
          "date": {
            "type": "string"
          },
          "validUntil": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "date"
        ]
      }
    },
    "publications": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "publisher": {
            "type": "string"
          },
          "date": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      }
    }
  }
}