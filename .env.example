# Copy this file to ".env" and fill in values.
#
# Never commit ".env" (it's gitignored). Only commit ".env.example".

# Supabase project settings (shared aliases used across app/runtime/scripts)
SUPABASE_PROJECT_REF=dbdzzhshmigewyprahej
SUPABASE_URL=https://dbdzzhshmigewyprahej.supabase.co
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://dbdzzhshmigewyprahej.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
VITE_SUPABASE_URL=https://dbdzzhshmigewyprahej.supabase.co
VITE_SUPABASE_ANON_KEY=

# Feature flags (web)
VITE_FF_SHELL_V2=true
VITE_FF_ASSISTANT_DOCK=true
VITE_FF_AGENTS_CONFIG_UI=true
VITE_FF_MCP_PLACEHOLDER_UI=true
VITE_FF_PROVIDER_CONNECTION_FLOWS=true
VITE_FF_COMMANDS_UI=true

# Server/worker-only secret (do NOT expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# Optional: direct Postgres connection string (server/worker only)
# Example: postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=

# Conversion service (Cloud Run <-> Supabase Edge Functions)
CONVERSION_SERVICE_URL=
CONVERSION_SERVICE_KEY=
TRACK_B_WORKER_KEY=
TRACK_B_CHUNK_MAX_CHARS=1200
TRACK_B_EMBED_DIMENSIONS=8
UNSTRUCTURED_TRACK_SERVICE_URL=
TRACK_B_SERVICE_KEY=
UNSTRUCTURED_API_KEY=
UNSTRUCTURED_API_URL=
TRACK_B_PARTITION_MODE=auto

# Smoke test / script aliases
TEST_EMAIL=
TEST_PASSWORD=


# AI provider API keys (used by worker Edge Function)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# MCP / research provider keys
# Local developer env ownership is repo-root only; do not create _agchain/.env.
EXA_API_KEY=
PERPLEXITY_API_KEY=
QDRANT_URL=
MILVUS_ADDRESS=
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=

# Supabase CLI / Management API (personal access token)
# Generate at: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# Superuser access (comma-separated emails for admin controls page)
SUPERUSER_EMAIL_ALLOWLIST=

# Social login (platform-api OAuth attempt tracking)
# Comma-separated origins that platform-api will accept for OAuth attempts.
# Must include every origin the frontend can run on (local dev + production).
AUTH_REDIRECT_ORIGINS=http://localhost:5374,http://127.0.0.1:5374,http://localhost:5375,http://127.0.0.1:5375
# Browser-side redirect origin (must match one of AUTH_REDIRECT_ORIGINS above).
VITE_AUTH_REDIRECT_ORIGIN=
