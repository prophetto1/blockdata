# ===========================================
# MCP SERVER ENVIRONMENT VARIABLES
# Organized by server name (matches migrate.sql)
# ===========================================
# NOTE: migrate.sql uses container names for Docker networking
#       (neo4j:7687, qdrant:6333, milvus:19530)
#       These localhost values are for LOCAL development only

# --- exa ---
EXA_API_KEY=

# --- perplexity-ask ---
PERPLEXITY_API_KEY=

# --- graphiti (Neo4j) ---
# Docker: bolt://neo4j:7687 | Local: bolt://localhost:7687
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# --- graphiti, qdrant (shared) ---
OPENAI_API_KEY=

# --- qdrant ---
# Docker: http://qdrant:6333 | Local: http://localhost:6333
QDRANT_URL=http://localhost:6333
