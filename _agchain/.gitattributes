# Default: normalize text files to LF in the repository.
* text=auto eol=lf

# Windows-native scripts.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.ico binary
*.zip binary
*.gz binary
*.7z binary
*.db binary
*.duckdb binary

# Shapefile-related binaries
*.shp binary
*.shx binary
*.dbf binary

# Data files
*.csv binary
*.jsonl binary
