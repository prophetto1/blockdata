h# Copy this file to ".env" and fill in values.
# Never commit ".env" (it's gitignored). Only commit ".env.example".

VITE_SUPABASE_URL=https://dbdzzhshmigewyprahej.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_FF_SHELL_V2=true
VITE_FF_ASSISTANT_DOCK=true
VITE_FF_AGENTS_CONFIG_UI=true
VITE_FF_MCP_PLACEHOLDER_UI=true
VITE_FF_PROVIDER_CONNECTION_FLOWS=true
VITE_FF_COMMANDS_UI=true

# Social login redirect origin
# Set to the exact origin the browser uses (e.g. http://localhost:5374).
# If unset, falls back to window.location.origin at runtime.
# Must match an origin in AUTH_REDIRECT_ORIGINS on platform-api.
VITE_AUTH_REDIRECT_ORIGIN=

# Google Drive Picker (Assets page cloud import)
# NOTE: These are NOT Supabase social-login credentials.
# Social login (Google/GitHub) is configured in the Supabase dashboard,
# not here. These keys are only for the Google Drive Picker on the Assets page.
VITE_GOOGLE_API_KEY=           # Google Cloud API key (restricted to Picker API)
VITE_GOOGLE_CLIENT_ID=         # OAuth 2.0 Client ID (web application type)
VITE_GOOGLE_APP_ID=            # Google Cloud project number (numeric)
VITE_DROPBOX_APP_KEY=          # Dropbox App Key (from Dropbox App Console, Chooser API)
