h# Copy this file to ".env" and fill in values.
# Never commit ".env" (it's gitignored). Only commit ".env.example".

VITE_SUPABASE_URL=https://dbdzzhshmigewyprahej.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_FF_SHELL_V2=true
VITE_FF_ASSISTANT_DOCK=true
VITE_FF_AGENTS_CONFIG_UI=true
